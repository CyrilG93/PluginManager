{
  "name": "cyril-plugin-manager",
  "version": "0.2.1",
  "description": "A desktop manager for installing Cyril Plugin releases from GitHub.",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node scripts/start-electron.js",
    "lint": "eslint src scripts tests",
    "test": "node --test",
    "check": "npm run lint && npm test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis --x64"
  },
  "keywords": [
    "adobe",
    "plugins",
    "premiere",
    "installer"
  ],
  "author": "CyrilG93",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/CyrilG93/PluginManager.git"
  },
  "build": {
    "appId": "com.cyrilplugin.manager",
    "productName": "Cyril Plugin Manager",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "data/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "icons/app-icon.png",
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "icons/app-icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cyril Plugin Manager"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.31.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16"
  }
}
